rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(field1, field2) {
      return isAuthenticated() && (
        resource.data[field1] == request.auth.uid ||
        resource.data[field2] == request.auth.uid
      );
    }

    // Validate that a write doesn't add unexpected fields
    function hasOnlyExpectedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Rate limiting: prevent rapid-fire writes (max 1 write per 2 seconds per document)
    // Uses the document's own updatedAt timestamp when available
    function isNotRateLimited() {
      return !('updatedAt' in resource.data) ||
        request.time > resource.data.updatedAt + duration.value(2, 's');
    }

    // ── Users Collection ──────────────────────────────────────────────
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
        // Prevent role escalation, but allow setting role if it doesn't exist yet
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
         !('role' in resource.data) ||
         request.resource.data.role == resource.data.role);
      allow delete: if false; // Never allow profile deletion via client

      match /alerts/{alertId} {
        allow read, write: if isOwner(userId);
      }
      
      match /tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }

      match /expenses/{expenseId} {
        allow read, write: if isOwner(userId);
      }

      match /irrigationZones/{zoneId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Products Collection ───────────────────────────────────────────
    // Authenticated users can read all products; only owner can modify
    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.farmerUid == request.auth.uid &&
        request.resource.data.quantity > 0 &&
        request.resource.data.price >= 0;
      allow update: if isAuthenticated() &&
        resource.data.farmerUid == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.farmerUid == request.auth.uid;
    }

    // ── Deals Collection ──────────────────────────────────────────────
    // Only participants in the deal can read/update
    match /deals/{dealId} {
      allow read: if isAuthenticated() &&
        (resource.data.farmerUid == request.auth.uid ||
         resource.data.customerUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isParticipant('farmerUid', 'customerUid');
      allow delete: if false; // Deals are permanent records
    }

    // ── Negotiations Collection ───────────────────────────────────────
    // Only participants can access negotiations
    match /negotiations/{negotiationId} {
      allow read: if isAuthenticated() &&
        (resource.data.farmerUid == request.auth.uid ||
         resource.data.customerUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.farmerUid == request.auth.uid ||
         resource.data.customerUid == request.auth.uid);

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 5000; // Message length limit
        allow update, delete: if false; // Messages are immutable
      }
    }

    // ── CSA Tiers ─────────────────────────────────────────────────────
    match /csaTiers/{tierId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.farmerUid == request.auth.uid &&
        request.resource.data.price >= 0;
      allow update, delete: if isAuthenticated() &&
        resource.data.farmerUid == request.auth.uid;
    }

    // ── CSA Subscriptions ─────────────────────────────────────────────
    match /csaSubscriptions/{subId} {
      allow read: if isAuthenticated() &&
        (resource.data.farmerUid == request.auth.uid ||
         resource.data.customerUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isParticipant('farmerUid', 'customerUid');
      allow delete: if false; // Subscriptions should be cancelled, not deleted
    }

    // ── Weekly Availability ───────────────────────────────────────────
    match /weeklyAvailability/{farmerId} {
      allow read: if true;
      allow write: if isOwner(farmerId);
    }

    // ── Barter Listings ─────────────────────────────────────────────
    match /barterListings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.farmerUid == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.farmerUid == request.auth.uid;
    }

    // ── Barter Requests ─────────────────────────────────────────────
    match /barterRequests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.requesterUid == request.auth.uid ||
         resource.data.listerUid == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.requesterUid == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.requesterUid == request.auth.uid ||
         resource.data.listerUid == request.auth.uid);
      allow delete: if false;
    }

    // ── Finalized Barter Deals ──────────────────────────────────────
    match /finalizedBarterDeals/{dealId} {
      allow read: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid;
      allow create: if isAuthenticated(); // Created transparently via transactions 
      allow update: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid;
    }

    // ── Livestock ─────────────────────────────────────────────────────
    match /livestock/{userId}/{animalId} {
      allow read, write: if isOwner(userId);
    }

    // ── Farm Machinery ────────────────────────────────────────────────
    match /machineryListings/{machineryId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ── Rental Requests ───────────────────────────────────────────────
    match /machineryRentals/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.renterUid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.renterUid == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.renterUid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid);
      allow delete: if false;
    }

    // ── Community Connections ──────────────────────────────────────────
    match /connections/{connectionId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid in resource.data.participantUids || 
         resource.data.senderUid == request.auth.uid || 
         resource.data.recipientUid == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.senderUid == request.auth.uid;
      allow update: if isAuthenticated() &&
        (request.auth.uid in resource.data.participantUids ||
         resource.data.senderUid == request.auth.uid || 
         resource.data.recipientUid == request.auth.uid);
      allow delete: if isAuthenticated() &&
        (request.auth.uid in resource.data.participantUids ||
         resource.data.senderUid == request.auth.uid || 
         resource.data.recipientUid == request.auth.uid);
    }

    // ── Community Feed ────────────────────────────────────────────────
    match /community_feed/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.senderUid == request.auth.uid;
    }

    // ── Chats ──────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid in resource.data.participants ||
         chatId.matches('.*' + request.auth.uid + '.*'));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.text is string;
        allow update: if isAuthenticated() && 
          resource.data.senderUid == request.auth.uid; 
        allow delete: if false; // Instead of delete, chatService sets deleted: true
      }
    }

    // ── Retail Orders ─────────────────────────────────────────────────
    match /retailOrders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.customerUid == request.auth.uid ||
         resource.data.farmerUid == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.customerUid == request.auth.uid &&
        request.resource.data.quantity > 0;
      allow update: if isAuthenticated() &&
        (resource.data.customerUid == request.auth.uid ||
         resource.data.farmerUid == request.auth.uid);
      allow delete: if false; // Orders are permanent records
    }

    // ── Notifications ─────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid;
    }

    // ── Farm Management ───────────────────────────────────────────────
    // Note: Farm Management rules have been moved to the Users Collection block
    // to correctly match the data structure (users/{userId}/tasks, etc.)

    // ── Trust & Transparency System ─────────────────────────────────
    match /farmerVerifications/{farmerUid} {
      allow read: if true;
      allow create, update: if isOwner(farmerUid);
      allow delete: if false;
    }

    match /productPassports/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.farmerUid == request.auth.uid;
      allow update, delete: if false; // Passports are immutable
    }

    match /farmerReviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.customerUid == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.customerUid == request.auth.uid;
      allow delete: if false;
    }

    // ── Disease Scans (saved from Crop Health Scanner) ────────────────
    match /diseaseScans/{scanId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.farmerUid == request.auth.uid;
      allow update, delete: if false; // Scan records are immutable
    }

    // ── Soil Analyses (saved from Soil Health Scanner) ────────────────
    match /soilAnalyses/{farmerUid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(farmerUid);
      allow delete: if false;
    }

    // ── Catch-all: Deny everything else ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
